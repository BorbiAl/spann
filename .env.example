SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_USE_SERVICE_ROLE=false
GROQ_API_KEY=your-groq-api-key
REDIS_URL=redis://valkey:6379/0
JWT_SECRET=replace-with-strong-secret
MESH_RELAY_TOKEN_SECRET=replace-with-mesh-relay-secret
MESH_SYNC_SHARED_TOKEN=replace-with-shared-internal-sync-token
NEXT_PUBLIC_API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

API_HOST=0.0.0.0
API_PORT=8000
CHAT_SERVER_ADDR=:8080
CHAT_MESSAGE_RATE_PER_MINUTE=60
MESH_RELAY_ADDR=0.0.0.0:8090
MESH_DAEMON_PORT=7070
MESH_DAEMON_BIND=127.0.0.1
CELERY_BROKER_URL=redis://valkey:6379/0
CELERY_RESULT_BACKEND=redis://valkey:6379/1
FASTAPI_MESH_SYNC_URL=http://backend:8000/mesh/sync
ENV=development
TEST_MODE=false
AUTH_FALLBACK_ENABLED=false

# Frontend API configuration (Vite)
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8000

# Additional backend verification defaults
APP_ENV=development
APP_VERSION=1.0.0
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800
DATABASE_URL=postgresql://spann:spann@postgres:5432/spann
TEST_DATABASE_URL=postgresql://spann:spann@localhost:5433/spann_test
TEST_REDIS_URL=redis://localhost:6380/0
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_TIMEOUT=30
GROQ_MAX_RETRIES=2
MESH_TIMESTAMP_TOLERANCE=300
MESH_NONCE_TTL=300
RATE_LIMIT_AUTH=10
RATE_LIMIT_MESSAGES=60
RATE_LIMIT_TRANSLATE=100
RATE_LIMIT_PUBLIC=300
RATE_LIMIT_WINDOW=60
GO_CHAT_HOST=0.0.0.0
GO_CHAT_PORT=8080
GO_CHAT_REDIS_URL=redis://valkey:6379/0
GO_CHAT_JWT_SECRET=replace-with-strong-jwt-secret
RUST_RELAY_HOST=0.0.0.0
RUST_RELAY_PORT=8090
RUST_RELAY_REDIS_URL=redis://valkey:6379/0
LOG_LEVEL=INFO
LOG_FORMAT=json
