{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "composite": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "rootDir": "electron",
    "outDir": "dist-electron",

    /* Strict */
    "strict": true,
    "skipLibCheck": true,

    /* Node / Electron globals */
    "types": ["node"]
  },
  "include": ["electron"]
}
