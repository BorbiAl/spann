{
  "name": "spann",
  "version": "1.0.0",
  "description": "Spann — Reach Anyone. Anywhere. Always.",
  "main": "desktop/main.cjs",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "desktop:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron desktop/main.cjs\"",
    "build": "tsc && vite build && electron-builder",
    "packages:build": "turbo run build --filter=./packages/*",
    "packages:dev": "turbo run dev --filter=./packages/*",
    "packages:typecheck": "turbo run typecheck --filter=./packages/*",
    "desktop:build": "npm run build",
    "build:win": "electron-builder --win",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src electron --ext .ts,.tsx",
    "backend": "python -m uvicorn app.main:app --app-dir backend --host 0.0.0.0 --port 8000",
    "backend:legacy": "node server/index.js",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:add:android": "npx cap add android",
    "mobile:add:ios": "npx cap add ios",
    "mobile:android": "npm run mobile:sync && npx cap open android",
    "mobile:ios": "npm run mobile:sync && npx cap open ios"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BorbiAl/spann.git"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "desktop",
    "communication"
  ],
  "author": "BorisAl",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/BorbiAl/spann/issues"
  },
  "homepage": "https://github.com/BorbiAl/spann#readme",
  "dependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/core": "^7.4.3",
    "@capacitor/ios": "^7.4.3",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tanstack/react-query": "^5.62.16",
    "@tanstack/react-virtual": "^3.11.2",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "framer-motion": "^11.15.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.5.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "turbo": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^8.0.8",
    "wait-on": "^8.0.1"
  }
}
